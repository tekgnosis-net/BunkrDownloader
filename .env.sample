# Server configuration
API_HOST=0.0.0.0
API_PORT=8887

# Local paths that will be mounted into the container (docker-compose)
DOWNLOADS_DIR=./Downloads
LOGS_DIR=./logs

# Session log location for CLI/Web runs (overrides default session.log)
SESSION_LOG_PATH=./logs/session.log

# Container image tag (defaults to latest)
IMAGE_TAG=latest
UID=1000
GID=1000

# Frontend development settings
VITE_DEV_SERVER_PORT=5173
VITE_API_PROXY=http://localhost:8887
VITE_WS_BASE_URL=

# ---------------------------------------------------------------------------
# Memory hygiene (PR2)
# ---------------------------------------------------------------------------
# Maximum number of events retained per job in the in-memory ring buffer.
# Clients whose cursor falls below the retained floor get a 410 Gone so they
# can reset rather than silently missing history.
JOB_EVENT_RETENTION=2000
# Terminal jobs (completed/failed/cancelled) older than this are evicted
# by the background reaper.
JOB_TTL_HOURS=24
# How often the reaper scans for stale jobs (seconds).
JOB_REAPER_INTERVAL_SECONDS=900

# ---------------------------------------------------------------------------
# Path sandbox (PR2)
# ---------------------------------------------------------------------------
# Incoming custom_path and /api/directories?basePath values must resolve
# under this root. Set to / to restore the pre-PR2 "anywhere the container
# can reach" behaviour (not recommended for public-facing deployments).
#ALLOWED_DOWNLOAD_ROOT=/app/Downloads

# ---------------------------------------------------------------------------
# API auth + CORS (PR2)
# ---------------------------------------------------------------------------
# Shared bearer token. When set, every /api/* request must carry
# `Authorization: Bearer <token>` and every /ws/* connection must include
# `?token=<token>`. When unset, the API is unauthenticated (a warning is
# logged on startup) — safe only on a trusted LAN.
#API_ACCESS_TOKEN=

# Comma-separated list of CORS-allowed origins. Leave unset to match the
# localhost regex (covers Vite dev + uvicorn defaults). Set an explicit list
# for production: https://dash.example.com,https://admin.example.com
#ALLOWED_ORIGINS=
#ALLOWED_ORIGIN_REGEX=https?://(localhost|127\.0\.0\.1)(:\d+)?
